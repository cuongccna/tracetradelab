# ════════════════════════════════════════════════════════════════
#  TraceTradeLab — Environment Configuration
#  Copy file này thành .env và điền các giá trị thực
#  cp .env.example .env && nano .env
# ════════════════════════════════════════════════════════════════

# ── DeepSeek API ─────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── TradingAgents LLM settings ────────────────────────────────────
TRADINGAGENTS_LLM_PROVIDER=deepseek
TRADINGAGENTS_LLM_BACKEND_URL=https://api.deepseek.com
TRADINGAGENTS_DEEP_THINK_LLM=deepseek-v4-flash
TRADINGAGENTS_QUICK_THINK_LLM=deepseek-v4-flash
TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
TRADINGAGENTS_MAX_RISK_ROUNDS=1
TRADINGAGENTS_MAX_RECUR_LIMIT=45

# ── Telegram Bot (tùy chọn) ───────────────────────────────────────
# Lấy token từ @BotFather, chat_id từ @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Dashboard URL (để Telegram link về đúng chỗ) ─────────────────
# Nếu dùng Cloudflare Tunnel: DASHBOARD_URL=https://xxx.trycloudflare.com
DASHBOARD_URL=http://localhost:8888

# ── Paths (mặc định dùng /opt/TraceTradeLab, thay đổi nếu cần) ───
# TRACETRADE_BASE=/opt/TraceTradeLab
# SIGNAL_DB_PATH=/opt/TraceTradeLab/signal_bridge/signals.db

# ── Freqtrade (nếu khác mặc định) ────────────────────────────────
# FREQTRADE_API_URL=http://127.0.0.1:8080/api/v1
# FREQTRADE_USER=admin
# FREQTRADE_PASS=your_password_here

# ── Network / Proxy fallback for VPS bị chặn/rate-limit ──────────
# Dùng một URI proxy đầy đủ, ví dụ:
# TRACE_HTTPS_PROXY=http://user:pass@proxy-host:port
# TRACE_HTTP_PROXY=http://user:pass@proxy-host:port
# TRACE_ALL_PROXY=socks5://user:pass@proxy-host:port
TRACE_HTTPS_PROXY=
TRACE_HTTP_PROXY=
TRACE_ALL_PROXY=

# 2captcha placeholders. Lưu ý: 2captcha API key không phải proxy HTTP;
# nếu nhà cung cấp đưa proxy URI riêng, điền TWOCAPTCHA_PROXY_URI.
TWOCAPTCHA_API_KEY=
TWOCAPTCHA_PROXY_URI=
TWO_CAPTCHA_API_KEY=
TWO_CAPTCHA_PROXY_URI=

# Optional official X/Twitter recent-search credentials.
# X API v2 recent search requires an app bearer token.
X_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAAOGV9wEAAAAAhkKhZhhAEOm3%2BYv6XM4xDqP%2Ff1Y%3DPPZ60yb0hWOCgvjB4zY7n6mcnchAC7D7C7eqMKAQDaiuIwG4rT
TWITTER_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAAOGV9wEAAAAAhkKhZhhAEOm3%2BYv6XM4xDqP%2Ff1Y%3DPPZ60yb0hWOCgvjB4zY7n6mcnchAC7D7C7eqMKAQDaiuIwG4rT

# Auto tạo adaptive-risk proposal sau khi feedback_collector ghi outcome mới.
# Không tự apply config trừ khi bạn bấm Apply trên dashboard/API.
TRACE_AUTO_ADAPTIVE_RISK=true
