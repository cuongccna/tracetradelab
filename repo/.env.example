# ════════════════════════════════════════════════════════════════
#  TraceTradeLab — Environment Configuration
#  Copy file này thành .env và điền các giá trị thực
#  cp .env.example .env && nano .env
# ════════════════════════════════════════════════════════════════

# ── DeepSeek API ─────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── TradingAgents LLM settings ────────────────────────────────────
TRADINGAGENTS_LLM_PROVIDER=deepseek
TRADINGAGENTS_LLM_BACKEND_URL=https://api.deepseek.com
TRADINGAGENTS_DEEP_THINK_LLM=deepseek-v4-flash
TRADINGAGENTS_QUICK_THINK_LLM=deepseek-v4-flash
TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
TRADINGAGENTS_MAX_RISK_ROUNDS=1
TRADINGAGENTS_MAX_RECUR_LIMIT=45

# ── Telegram Bot (tùy chọn) ───────────────────────────────────────
# Lấy token từ @BotFather, chat_id từ @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Dashboard URL (để Telegram link về đúng chỗ) ─────────────────
# Nếu dùng Cloudflare Tunnel: DASHBOARD_URL=https://xxx.trycloudflare.com
DASHBOARD_URL=http://localhost:8888

# ── Paths (mặc định dùng /opt/TraceTradeLab, thay đổi nếu cần) ───
# TRACETRADE_BASE=/opt/TraceTradeLab
# SIGNAL_DB_PATH=/opt/TraceTradeLab/signal_bridge/signals.db

# ── Freqtrade (nếu khác mặc định) ────────────────────────────────
# FREQTRADE_API_URL=http://127.0.0.1:8080/api/v1
# FREQTRADE_USER=admin
# FREQTRADE_PASS=your_password_here
