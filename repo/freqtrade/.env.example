# ── Freqtrade API Server secrets ─────────────────────────────────
# Tạo chuỗi random: python3 -c "import secrets; print(secrets.token_hex(32))"
FREQTRADE_JWT_SECRET=CHANGE_ME_RANDOM_64CHAR_STRING
FREQTRADE_WS_TOKEN=CHANGE_ME_RANDOM_STRING
FREQTRADE_API_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Bind UI/API native của Freqtrade.
# Giữ 127.0.0.1 khi dùng SSH tunnel/reverse proxy; chỉ đổi 0.0.0.0 nếu VPS đã có firewall.
FREQTRADE_BIND_HOST=127.0.0.1

# ── Telegram native của Freqtrade (tùy chọn) ─────────────────────
# Khác với telegram_reporter.py — đây là Freqtrade gửi trực tiếp
FREQTRADE_TELEGRAM_ENABLED=false
FREQTRADE_TELEGRAM_TOKEN=
FREQTRADE_TELEGRAM_CHAT_ID=
