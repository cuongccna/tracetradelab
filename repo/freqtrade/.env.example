# ── Freqtrade API Server secrets ─────────────────────────────────
# Tạo chuỗi random: python3 -c "import secrets; print(secrets.token_hex(32))"
FREQTRADE_JWT_SECRET=CHANGE_ME_RANDOM_64CHAR_STRING
FREQTRADE_WS_TOKEN=CHANGE_ME_RANDOM_STRING
FREQTRADE_API_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Bind UI/API native của Freqtrade.
# Giữ 127.0.0.1 khi dùng SSH tunnel/reverse proxy; chỉ đổi 0.0.0.0 nếu VPS đã có firewall.
FREQTRADE_BIND_HOST=127.0.0.1

# ── Telegram native của Freqtrade ────────────────────────────────
# ⚠️  QUAN TRỌNG: Phải dùng bot TOKEN RIÊNG, khác hoàn toàn với TELEGRAM_BOT_TOKEN
#     ở repo root .env (telegram_reporter.py).
#     Lý do: Freqtrade dùng polling (getUpdates). Nếu dùng cùng token với bất kỳ
#     service nào có set webhook → Freqtrade sẽ KHÔNG nhận được lệnh nào.
#
# Bước setup:
#   1. Tạo bot MỚI qua @BotFather → lấy TOKEN riêng cho Freqtrade
#   2. Lấy CHAT_ID của bạn: nhắn tin cho @userinfobot → xem "Your Id"
#   3. Xóa webhook nếu có: curl "https://api.telegram.org/bot<TOKEN>/deleteWebhook?drop_pending_updates=true"
#   4. Nhắn /start cho bot (bắt buộc sau mỗi lần restart container)
#   5. Điền CHAT_ID vào allowed_chat_ids trong config.json:
#      "allowed_chat_ids": [YOUR_CHAT_ID_NUMBER]
#      (allowed_chat_ids là mảng số nguyên, KHÔNG set được qua env var)
#
# LƯU Ý: Sau khi đổi token/chat_id → rebuild: docker compose up -d --force-recreate
FREQTRADE_TELEGRAM_ENABLED=false
FREQTRADE_TELEGRAM_TOKEN=
FREQTRADE_TELEGRAM_CHAT_ID=
