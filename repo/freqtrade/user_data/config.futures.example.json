{
  "$schema": "https://schema.freqtrade.io/schema.json",
  "bot_name": "TraceTraderFuturesDry",
  "initial_state": "running",
  "strategy": "AISignalLongShortStrategy",
  "max_open_trades": 2,
  "stake_currency": "USDT",
  "stake_amount": 80,
  "tradable_balance_ratio": 0.35,
  "fiat_display_currency": "USD",
  "timeframe": "1h",
  "minimal_roi": {
    "0": 0.035,
    "180": 0.022,
    "480": 0.012,
    "960": 0
  },
  "stoploss": -0.018,
  "dry_run": true,
  "dry_run_wallet": 1000,
  "cancel_open_orders_on_exit": true,
  "trading_mode": "futures",
  "margin_mode": "isolated",
  "exchange": {
    "name": "binance",
    "key": "",
    "secret": "",
    "ccxt_config": {
      "options": {
        "defaultType": "future"
      }
    },
    "ccxt_async_config": {
      "options": {
        "defaultType": "future"
      }
    },
    "pair_whitelist": [
      "BTC/USDT:USDT",
      "ETH/USDT:USDT",
      "SOL/USDT:USDT"
    ],
    "pair_blacklist": []
  },
  "entry_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1,
    "price_last_balance": 0.0,
    "check_depth_of_market": {
      "enabled": true,
      "bids_to_ask_delta": 1.08
    }
  },
  "exit_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1
  },
  "unfilledtimeout": {
    "entry": 5,
    "exit": 5,
    "exit_timeout_count": 0,
    "unit": "minutes"
  },
  "pairlists": [
    {
      "method": "StaticPairList"
    }
  ],
  "telegram": {
    "enabled": false,
    "token": "",
    "chat_id": ""
  },
  "api_server": {
    "enabled": true,
    "listen_ip_address": "0.0.0.0",
    "listen_port": 8080,
    "verbosity": "error",
    "enable_openapi": false,
    "jwt_secret_key": "overridden_by_environment",
    "ws_token": "overridden_by_environment",
    "CORS_origins": [],
    "username": "admin",
    "password": "overridden_by_environment"
  },
  "force_entry_enable": false,
  "internals": {
    "process_throttle_secs": 5
  }
}
